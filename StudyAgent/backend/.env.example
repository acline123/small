# DeepSeek Chat API（通过 token-cloud 代理访问）
# 如果你的 Key 来自 DeepSeek 官方，BASE_URL 改为 https://api.deepseek.com
# 如果你的 Key 来自 token-cloud 代理，BASE_URL 改为 https://www.token-cloud.cn/v1
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://www.token-cloud.cn/v1
DEEPSEEK_MODEL=DeepSeek-V4-Flash

# Embedding API（OpenAI 兼容格式）
# 说明：DeepSeek 官方暂未提供 Embedding 端点，此处使用 OpenAI 兼容 Embedding 服务
# 推荐：SiliconFlow 注册后使用 BAAI/bge-m3（中文效果好）
EMBEDDING_API_KEY=sk-your-key-here
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3

# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true

# 全网搜索（DuckDuckGo，无需 API Key）
WEB_SEARCH_MAX_RESULTS=5
